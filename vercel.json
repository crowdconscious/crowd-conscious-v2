{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": ["iad1"],
  "functions": {
    "app/api/cron/agents/ceo-digest/route.ts": { "maxDuration": 300 },
    "app/api/cron/agents/inbox-curator/route.ts": { "maxDuration": 300 },
    "app/api/cron/agents/content-creator/route.ts": { "maxDuration": 300 },
    "app/api/cron/agents/news-monitor/route.ts": { "maxDuration": 300 },
    "app/api/cron/agents/sponsor-report/route.ts": { "maxDuration": 300 },
    "app/api/cron/newsletter/route.ts": { "maxDuration": 300 },
    "app/api/predictions/admin/send-newsletter/route.ts": { "maxDuration": 300 },
    "app/api/cron/live-reminders/route.ts": { "maxDuration": 120 },
    "app/api/cron/live-auto-end/route.ts": { "maxDuration": 120 },
    "app/api/cron/monthly-impact/route.ts": { "maxDuration": 120 },
    "app/api/cron/pulse-auto-resolve/route.ts": { "maxDuration": 120 },
    "app/api/cron/reengagement-inactive/route.ts": { "maxDuration": 120 },
    "app/api/predictions/admin/run-agent/route.ts": { "maxDuration": 300 },
    "app/api/**/*.ts": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/cron/agents/news-monitor",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/agents/inbox-curator",
      "schedule": "5 14 * * *"
    },
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 14 * * 1,3,5"
    },
    {
      "path": "/api/cron/agents/content-creator",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/agents/ceo-digest",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/reengagement-inactive",
      "schedule": "0 16 * * 1"
    },
    {
      "path": "/api/cron/live-reminders",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/live-auto-end",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/pulse-auto-resolve",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/agents/sponsor-report",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/monthly-impact",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/archive",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/terms-and-conditions",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    }
  ]
}
